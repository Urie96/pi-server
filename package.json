{
  "name": "pi-server",
  "version": "0.1.0",
  "description": "Long-running HTTP bridge around pi-coding-agent for xiaozhi-server-rs",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "node --watch --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}